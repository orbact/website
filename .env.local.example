# ============================================
# ORBACT AI WEBSITE - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to git (it's already in .gitignore)

# ============================================
# NOTE: Gemini API Key
# ============================================
# The Gemini API key is now stored SERVER-SIDE in Supabase Edge Functions
# for security. You do NOT need VITE_GEMINI_API_KEY in this file anymore.
# See API_SECURITY.md for setup instructions.

# ============================================
# SUPABASE (Required for Database & Storage)
# ============================================
# Get these from your Supabase project dashboard
# URL format: https://[project-ref].supabase.co
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================
# ADMIN AUTHENTICATION (Required for Admin Panel)
# ============================================
# Set a strong password for admin access
# This is used for the Ctrl+Alt+O admin login
VITE_ADMIN_PASSWORD=your_secure_admin_password_here

# Google reCAPTCHA v2 Site Key (Required for Admin Login)
# Get from: https://www.google.com/recaptcha/admin/create
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# ============================================
# OPTIONAL: WEBHOOK FOR CONTACT FORM
# ============================================
# Make.com webhook URL for contact form submissions
# This is optional - contact form won't work without it
VITE_MAKE_WEBHOOK_URL=your_make_webhook_url_here

# ============================================
# NOTES
# ============================================
# - All variables must start with VITE_ to be accessible in the browser
# - Never commit .env.local to version control
# - Restart dev server (npm run dev) after changing values
# - For production, set these in your hosting platform's environment settings
